# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# ── OpenAI (standard API) ────────────────────────────────────────
# Used by: src/pipeline/llm_layer.py  (TRANSLATE_NORMALISE fields)
# Phase 2:  src/pipeline/ocr_gate.py  (GPT-4o Vision OCR)
OPENAI_API_KEY=your-openai-api-key-here

# ── Azure OpenAI (alternative to standard OpenAI) ────────────────
# Uncomment and set these, then update llm_layer.py to use AzureOpenAI client.
# OPENAI_API_BASE=https://<your-resource>.openai.azure.com/
# OPENAI_API_VERSION=2024-02-01

# ── Azure Document Intelligence (Phase 2 OCR alternative) ────────
# Used by: src/pipeline/ocr_gate.py (Option B)
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-di-key-here

# ── Thresholds ───────────────────────────────────────────────────
# OCR_CONFIDENCE_THRESHOLD=0.75
