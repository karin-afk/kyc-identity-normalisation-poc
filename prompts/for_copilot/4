  def extract_name_and_alias(text: str, language: str) -> dict:
    """
    Splits an alias phrase into primary name and alias name(s).
    Algorithm:
      1. Try each trigger pattern for the given language (and always try "en" patterns).
      2. If a trigger is found, split on the trigger:
         - primary_text = text before the trigger (stripped)
         - alias_text   = text after the trigger (stripped)
      3. If no trigger found, treat the entire text as the primary name.
      4. Return:
         {
           "primary_text": str,
           "alias_text": str | None,
           "trigger_found": str | None,  # the matched trigger pattern
           "split_method": "trigger" | "no_split"
         }
    """

  def process_analyst_field(
      text: str,
      language: str,
      transliterate_fn: callable,   # pass the existing transliteration function
      llm_fn: callable | None       # pass the existing LLM function (may be None)
  ) -> dict:
    """
    Processes a TRANSLATE_ANALYST field end-to-end.
    Steps:
      1. Call extract_name_and_alias(text, language)
      2. Transliterate/translate primary_text using transliterate_fn or llm_fn
         as appropriate for the language (same routing logic as normal pipeline)
      3. If alias_text is not None:
         a. Transliterate/translate alias_text using the same routing logic
         b. Combine as: "{primary_normalised} ALSO KNOWN AS {alias_normalised}"
      4. Return a full result dict with:
         - processing_method = "TRANSLITERATE+ANALYST" or "LLM+ANALYST"
         - review_required = True always for TRANSLATE_ANALYST fields
         - review_reason = "Analyst field: alias phrase extracted and normalised"
         - allowed_variants includes both primary-only and combined forms
    """

