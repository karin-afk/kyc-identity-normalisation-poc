  def _normalise_german(text: str, field_type: str) -> dict:
    """
    Normalises German-script Latin text.
    - Primary: apply GERMAN_UMLAUT_EXPANSIONS (Ä→AE, ß→SS)
    - Variants: apply GERMAN_UMLAUT_DROPS (Ä→A, ß→S) and add to allowed_variants
    - Both forms (expanded and dropped) must be in allowed_variants
    - Hyphenated given names: include space-separated variant
    - Particle "von/van/zu": preserve lowercase in primary,
      generate capitalised variant (Von/Van/Zu)
    - Returns full result dict with processing_method="TRANSLITERATE"
    """

  def _normalise_french(text: str, field_type: str) -> dict:
    """
    Normalises French-script Latin text.
    - Apply FRENCH_ACCENT_STRIP to produce normalised form
    - Ligatures: œ→oe, æ→ae in normalised form
    - Hyphenated given names: include space-separated variant in allowed_variants
    - Particle "de/du/de la/des/d'/l'":
        Primary: preserve particle lowercase
        Variant: generate particle-dropped form and particle-capitalised form
    - Apostrophe elision (d', l'): strip apostrophe in normalised form;
      keep apostrophe in primary; add fused form as variant
    - Returns full result dict
    """

  def _normalise_spanish(text: str, field_type: str) -> dict:
    """
    Normalises Spanish-script Latin text.
    - Apply SPANISH_ACCENT_STRIP
    - ñ: primary → n; add ny variant to allowed_variants
    - Particle "de/del/de la/de los/de las":
        Preserve in primary; generate dropped-particle variant
    - Double surnames: preserve both; generate single-surname variants
      (remove first surname, remove second surname) in allowed_variants
    - Returns full result dict
    """

  def _normalise_italian(text: str, field_type: str) -> dict:
    """
    Normalises Italian-script Latin text.
    - Apply ITALIAN_ACCENT_STRIP
    - Apostrophe particles (D', Dell', Dall', L', De', Degli'):
        Primary: strip apostrophe (D'Angelo → DAngelo)
        Allowed variants: fused (Dangelo), space-separated (D Angelo), 
                          particle-dropped (Angelo)
        NOTE: do NOT simplify double consonants — they are phonemically
              meaningful in Italian (Bianchi ≠ Bianci)
    - Returns full result dict
    """

  def _normalise_korean(text: str, field_type: str) -> dict:
    """
    Normalises Korean Hangul text using Revised Romanisation of Korea (RR).
    Use the `korean-romanizer` library (pip install korean-romanizer).
    If not available, fall back to a basic jamo decomposition.

    Post-processing after library call:
    1. Detect surname token (first syllable block for person_name fields).
    2. Look up surname in KOREAN_SURNAME_VARIANTS.
    3. Primary: use RR form from library.
    4. allowed_variants: all forms from KOREAN_SURNAME_VARIANTS lookup.
    5. Name order:
       - Primary: surname-first (Korean convention)
       - Variant: given-name-first (for Western DB compatibility)
    6. Given name: generate both fused and hyphenated forms as variants.
       Example: 박지훈 → primary "Bak Jihun", variants include:
         "Park Jihun", "Pak Jihun", "Park Ji-hun", "Bak Ji-hun",
         "Jihun Bak", "Jihun Park", "Ji-hun Park"
    7. Returns full result dict, review_required=True,
       review_reason="Korean name: surname romanisation variants generated"
    """

  def _normalise_english(text: str, field_type: str) -> dict:
    """
    Normalises English Latin-script text.
    Minimal processing only:
    1. Full-width digit → ASCII (Unicode NFKC normalisation)
    2. Apostrophe in surnames: O'Brien → O Brien (space) variant added
    3. Mac/Mc prefix: generate both capitalisation variants
       (MacDonald → Macdonald variant, and vice versa)
    4. St/Saint: generate both forms as variants for any St- surname
    5. Do NOT strip hyphens from hyphenated names without generating
       a variant — always add the hyphen-stripped form as a variant
    Returns full result dict, review_required=False for most cases,
    review_required=True only for ambiguous Mac/Mc cases.
    """

