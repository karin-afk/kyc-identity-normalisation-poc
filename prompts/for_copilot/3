  def kanji_numeral_to_int(text: str) -> int:
    """
    Converts Japanese Kanji numeral strings to integers.
    Handle: 一二三四五六七八九十百千 and 〇/零 for zero.
    Examples:
      "五十三" → 53
      "二十" → 20
      "三" → 3
      "二〇〇五" → 2005  (positional zero form used in modern dates)
      "十二" → 12
    """

  def detect_and_convert_japanese_era(date_str: str) -> dict:
    """
    Detects and converts Japanese era-year dates to Gregorian ISO 8601.
    Input examples:
      "昭和五十三年四月三日"     → 1978-04-03
      "平成三年十二月一日"       → 1991-12-01
      "令和三年一月五日"         → 2021-01-05
      "二〇〇五年十二月一日"     → 2005-12-01 (no era prefix — Gregorian in Kanji)
    Returns:
      {
        "normalised": "YYYY-MM-DD",
        "era_detected": str | None,
        "gregorian_year": int,
        "review_required": bool,
        "review_reason": str | None
      }
    Always set review_required=True for era-year conversions with reason:
      "Japanese era date converted — verify year: {era} {era_year} = {gregorian_year}"
    For Kanji Gregorian (no era prefix), set review_required=False.
    """

