  def validate_field(
      value: str,
      field_type: str,
      language: str
  ) -> dict:
    """
    Validates a single field before pipeline processing.
    Returns:
      {
        "valid": bool,
        "sanitised_value": str,   # value after safe sanitisation
        "rejection_reason": str | None,
        "warnings": list[str]
      }
    Checks in order:
    1. Type check — must be a string
    2. Length check — against MAX_FIELD_LENGTHS[field_type] or "default"
       If exceeded: truncate and add warning (do not reject)
    3. Prompt injection check — scan against PROMPT_INJECTION_PATTERNS (case-insensitive)
       If matched: set valid=False, rejection_reason="Prompt injection pattern detected"
    4. Script consistency check — verify text script is consistent with declared language:
       If language="ar" but no Arabic Unicode block characters present: add warning
       If language="ru"/"uk"/"bg" but no Cyrillic present: add warning
       If language="el" but no Greek present: add warning
       If language="zh"/"ja"/"ko" but no CJK characters present: add warning
       (these are warnings only — do not reject, as mixed-script input is legitimate)
    5. Null byte / control character check:
       Strip null bytes and C0/C1 control characters silently
       (except tab and newline which are stripped with a warning)
    """

  def validate_llm_routing(field_type: str, language: str) -> None:
    """
    Raises ValueError if an LLM call is attempted for a prohibited field type.
    Call this at the start of every function in llm_layer.py.
    Message format:
      "LLM routing violation: field_type '{field_type}' must never be sent 
       to the LLM. This is a governance control. Processing aborted."
    """

In pipeline.py, call validate_field() on every input record before any processing.
If valid=False, return a result dict with:
  normalised=None, confidence=0.0, review_required=True,
  review_reason=rejection_reason, should_use_in_screening=False

In llm_layer.py, call validate_llm_routing() at the entry point of every
public function before making any API call.

