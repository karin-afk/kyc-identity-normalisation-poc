      results: list[dict],
      golden_dataset_path: str,
      thresholds: dict = ACCURACY_THRESHOLDS,
      strict: bool = True
  ) -> dict:
    """
    Runs the full evaluation against the golden dataset and checks all thresholds.
    Parameters:
      results: list of pipeline output dicts
      golden_dataset_path: path to data/golden_dataset.csv
      thresholds: accuracy threshold dict
      strict: if True, raises RegressionGateFailure on any threshold breach;
              if False, returns report without raising
    Returns a report dict:
      {
        "passed": bool,
        "overall_accuracy": float,
        "per_language": dict[str, float],
        "per_method": dict[str, float],
