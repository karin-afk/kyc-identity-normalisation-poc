  def detect_calendar_system(date_str: str) -> str:
    """
    Returns "hijri", "gregorian", or "unknown".
    Hijri detection rules:
      - Year component is between 1300 and 1500 (covers ~1882–2077 Gregorian)
      - OR the string contains Arabic-Indic digits (٠١٢٣٤٥٦٧٨٩)
        AND the year component when converted is in that range
    Gregorian detection rules:
      - Year component is between 1900 and 2100
    Handle separators: / - . and space
    """

  def arabic_indic_to_ascii(text: str) -> str:
    """
    Converts Arabic-Indic digits (٠١٢٣٤٥٦٧٨٩) to ASCII (0123456789).
    Also converts Eastern Arabic-Indic (۰۱۲۳۴۵۶۷۸۹).
    Leaves all other characters unchanged.
    """

  def hijri_to_gregorian(year: int, month: int, day: int) -> tuple[int, int, int]:
    """
    Converts a Hijri (AH) date to Gregorian using the standard astronomical
    algorithm. Use the `hijri-converter` library (hijri_converter.convert.Hijri).
    If hijri-converter is not installed, fall back to the approximate formula:
      gregorian_year = year + 622 - (year // 33)
    and set review_required=True with reason "Hijri conversion used approximate 
    formula — hijri-converter library not installed".
    """

